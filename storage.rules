rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to read/write files only in their own folder
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // By default, deny all other access to storage
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
